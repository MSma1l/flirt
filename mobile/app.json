{
  "expo": {
    "name": "FLIRT",
    "slug": "flirt",
    "scheme": "flirt",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0F"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Îți deschidem galeria doar ca să alegi tu pozele pe care vrei să le pui în profil sau într-un Story. Nu citim restul galeriei.",
          "cameraPermission": "Folosim camera pentru verificarea prin selfie — confirmăm că profilul îți aparține — și ca să faci poze pe care le adaugi la profil sau într-un Story."
        }
      ],
      "expo-iap",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Folosim camera pentru verificarea prin selfie — confirmăm că profilul îți aparține — și ca să faci poze pe care le adaugi la profil sau într-un Story.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF2D78"
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "eu.flirt.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Folosim camera pentru verificarea prin selfie — confirmăm că profilul îți aparține — și ca să faci poze pe care le adaugi la profil sau într-un Story.",
        "NSPhotoLibraryUsageDescription": "Îți deschidem galeria doar ca să alegi tu pozele pe care vrei să le pui în profil sau într-un Story. Nu citim restul galeriei.",
        "NSLocationWhenInUseUsageDescription": "Folosim locația ca să-ți arătăm persoane și evenimente aproape de tine și ca să calculăm distanța până la ele. Nu afișăm niciodată locația ta exactă altor utilizatori."
      },
      "privacyManifests": {
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": [],
        "NSPrivacyCollectedDataTypes": [
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeEmailAddress",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
