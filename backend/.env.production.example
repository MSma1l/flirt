# ============================================================================ #
#  FLIRT — .env pentru PRODUCȚIE (api.flrt.md)
# ============================================================================ #
#
#   cp .env.production.example .env      # apoi completează tot ce e marcat
#
# Fiecare valoare marcată cu  <<< COMPLETEAZĂ >>>  TREBUIE pusă de tine. Restul au
# valori bune implicit.
#
# Nu e nevoie să ghicești dacă ai uitat ceva: `app/core/config.py` conține un
# GUARD de producție care REFUZĂ pornirea și îți listează exact ce lipsește. Îl poți
# rula înainte de deploy:
#
#   docker compose run --rm api python -c "from app.core.config import Settings; Settings(); print('config OK')"
#
# ⚠️  Fișierul `.env` conține CHEI. Nu îl comita (e în .gitignore), nu îl trimite pe
#     chat, ține-l cu `chmod 600` și doar pe server.
# ============================================================================ #


# ---------------------------------------------------------------------------- #
# 1. APLICAȚIE  (OBLIGATORIU)
# ---------------------------------------------------------------------------- #
APP_NAME=FLIRT
# Activează guardul de producție. Cu orice altă valoare, aplicația pornește cu
# integrări false (stub) — adică verificări de vârstă, plăți și SMS-uri simulate.
ENVIRONMENT=production
API_V1_PREFIX=/api/v1
# DEBUG=true în producție expune stack-trace-uri (căi de fișiere, versiuni, SQL).
# Guardul refuză pornirea dacă e true.
DEBUG=false


# ---------------------------------------------------------------------------- #
# 2. DOMENII ȘI TLS  (OBLIGATORIU)
# ---------------------------------------------------------------------------- #
# Numele public al API-ului. Decide `server_name` din nginx ȘI pentru ce nume cere
# certbot certificatul. Trebuie să existe un record DNS A: api.flrt.md → IP server.
DOMAIN=api.flrt.md

# Numele public al panoului de admin (SPA static, servit de același nginx).
# Certificatul Let's Encrypt e emis pentru AMBELE nume, într-o singură cerere.
# Trebuie și el record DNS A: admin-flirt-paty.flrt.md → ACELAȘI IP.
# Lasă gol dacă nu vrei (încă) panou de admin — atunci certificatul se emite doar
# pentru api.flrt.md, iar stack-ul pornește normal.
ADMIN_DOMAIN=admin-flirt-paty.flrt.md

# Email REAL, pentru avertizările Let's Encrypt de expirare (îți scriu cu 20, 10 și
# 1 zi înainte dacă reînnoirea automată s-a stricat). Fără el, certbot nu cere
# certificatul și rămâi pe self-signed = aplicația mobilă NU se poate conecta.
CERTBOT_EMAIL=<<< COMPLETEAZĂ >>>          # ex. admin@flrt.md

# true = certificat din mediul de TEST Let's Encrypt (neîncrezut de browsere, dar
# fără limite de rată). Pune-l pe true doar cât testezi procedura, apoi înapoi false
# și șterge volumul: docker compose down && docker volume rm backend_letsencrypt
CERTBOT_STAGING=false


# ---------------------------------------------------------------------------- #
# 3. CORS  (OBLIGATORIU)
# ---------------------------------------------------------------------------- #
# Cine are voie să cheme API-ul din BROWSER.
#
# Aplicația mobilă (React Native) NU trimite antetul `Origin` — pe ea CORS nu o
# afectează deloc. Singura suprafață web e panoul de admin, deci aici punem EXACT
# originea lui. Wildcard '*' e refuzat de guard (cu credențiale = oricine îți poate
# citi API-ul din browserul unui user logat).
# Mai multe origini: separate prin virgulă, fără spații.
CORS_ORIGINS=https://admin-flirt-paty.flrt.md


# ---------------------------------------------------------------------------- #
# 4. BAZA DE DATE  (OBLIGATORIU)
# ---------------------------------------------------------------------------- #
POSTGRES_USER=flirt
# Generează o parolă tare:   openssl rand -base64 32
# Guardul refuză pornirea dacă rămâne 'change_me'.
POSTGRES_PASSWORD=<<< COMPLETEAZĂ >>>
POSTGRES_DB=flirt
# În docker-compose, host/port sunt setate automat (db:5432). Nu le schimba decât
# dacă folosești un Postgres GESTIONAT, din afara stack-ului.
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Lasă GOL: se compune singur din variabilele de mai sus. Îl setezi doar dacă
# folosești un Postgres extern (ex. RDS):
#   postgresql+asyncpg://user:parola@host:5432/flirt
DATABASE_URL=


# ---------------------------------------------------------------------------- #
# 5. REDIS  (OBLIGATORIU în producție)
# ---------------------------------------------------------------------------- #
# Fără Redis, rate-limiting-ul cade tăcut pe o implementare in-memory. Cu 4 workeri
# gunicorn asta înseamnă limita reală × 4 (și zero la scale-out) — adică protecția
# anti-brute-force pe login/OTP practic nu există. Guardul refuză pornirea fără el.
# În docker-compose, `redis` e numele serviciului intern. Nu are port public.
REDIS_URL=redis://redis:6379/0


# ---------------------------------------------------------------------------- #
# 6. CHEI JWT — RS256  (OBLIGATORIU)
# ---------------------------------------------------------------------------- #
# Generează-le PE SERVER (cheia privată nu trebuie să iasă niciodată de acolo):
#
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   echo "JWT_PRIVATE_KEY=$(awk '{printf "%s\\n", $0}' private.pem)"
#   echo "JWT_PUBLIC_KEY=$(awk '{printf "%s\\n", $0}' public.pem)"
#
# Copiază cele două linii afișate aici (PEM pe o singură linie, cu `\n` literal —
# config-ul le normalizează). `scripts/bootstrap_server.sh` face asta automat.
#
# Rotația cheii invalidează TOATE tokenurile emise (toți userii se reloghează).
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY=<<< COMPLETEAZĂ >>>
JWT_PUBLIC_KEY=<<< COMPLETEAZĂ >>>
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30


# ============================================================================ #
#  7. INTEGRĂRI EXTERNE
#
#  Guardul de producție REFUZĂ orice provider lăsat pe 'stub' — un stub în producție
#  înseamnă verificare falsă: SMS-uri care nu pleacă, plăți „reușite" fără bani,
#  selfie-uri „verificate" fără să fie. Și refuză și modul 'live' FĂRĂ chei: ăla e
#  și mai rău, pentru că aplicația pornește „sănătoasă" și crapă abia la primul user.
# ============================================================================ #

# --- 7.1 STORAGE FOTO — S3 (OBLIGATORIU) ------------------------------------- #
# Singurul provider implementat în afară de stub: 's3' (merge cu orice serviciu
# compatibil S3: AWS S3, Backblaze B2, Cloudflare R2, Hetzner Object Storage).
#
# De unde iei cheile (AWS):
#   1. Bucket:  https://s3.console.aws.amazon.com/s3/buckets  → Create bucket
#      (blochează accesul public; fișierele se servesc prin URL-uri semnate)
#   2. Chei:    https://console.aws.amazon.com/iam/home#/users → user nou →
#      Security credentials → Create access key. Dă-i o politică ce permite DOAR
#      s3:PutObject/GetObject/DeleteObject pe bucket-ul tău (nu AdministratorAccess).
#      ATENȚIE: același user IAM are nevoie și de `rekognition:CompareFaces` (vezi 7.6).
STORAGE_PROVIDER=s3
S3_BUCKET=<<< COMPLETEAZĂ >>>              # ex. flirt-photos-prod
S3_REGION=<<< COMPLETEAZĂ >>>              # ex. eu-central-1
AWS_ACCESS_KEY_ID=<<< COMPLETEAZĂ >>>      # AKIA...
AWS_SECRET_ACCESS_KEY=<<< COMPLETEAZĂ >>>
# Bază de URL pentru fișiere (CDN în față, dacă ai). Folosit doar de providerul stub.
STORAGE_BASE_URL=https://cdn.flrt.md


# --- 7.2 GEOLOCAȚIE — Nominatim / OpenStreetMap (OBLIGATORIU, dar GRATUIT) ---- #
# 'nominatim' NU cere cheie API și nu costă nimic. E providerul recomandat.
GEO_PROVIDER=nominatim
GEO_BASE_URL=https://nominatim.openstreetmap.org
#
# ⚠️  GEO_USER_AGENT: politica de utilizare Nominatim cere un User-Agent care te
# identifică, cu un CONTACT REAL. Valoarea implicită (`contact@example.com`) duce la
# BLOCARE de către OSM — adică geocodarea se oprește, distanțele dispar din feed și
# raza de căutare devine inoperantă. Guardul refuză pornirea dacă rămâne example.com.
# Politica: https://operations.osmfoundation.org/policies/nominatim/
GEO_USER_AGENT=FLIRT/1.0 (<<< COMPLETEAZĂ: email real, ex. admin@flrt.md >>>)
#
# Plafon de geocodări NOI per cerere de feed (anti-DoS / anti-cost). Nu-l crește.
GEO_MAX_LOOKUPS_PER_REQUEST=25
# Cheie — necesară DOAR dacă treci pe GEO_PROVIDER=google sau mapbox (contra cost):
#   Google: https://console.cloud.google.com/google/maps-apis/credentials
#   Mapbox: https://account.mapbox.com/access-tokens/
GEO_API_KEY=


# --- 7.3 LOGIN SOCIAL — Apple / Google (OBLIGATORIU: cel puțin unul) ---------- #
# Guardul cere ca, în modul 'live', cel puțin unul dintre cele două ID-uri să existe.
# Apple e OBLIGATORIU pentru App Store dacă oferi login Google (Guideline 4.8).
SOCIAL_AUTH_MODE=live
# Google OAuth Client ID (tip „iOS"/„Android"/„Web", în funcție de platformă):
#   https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=<<< COMPLETEAZĂ >>>       # ...apps.googleusercontent.com
# Apple: „Services ID" din Sign in with Apple:
#   https://developer.apple.com/account/resources/identifiers/list/serviceId
APPLE_CLIENT_ID=<<< COMPLETEAZĂ >>>        # ex. md.flirt.signin


# --- 7.4 OTP prin SMS — Twilio (OBLIGATORIU) --------------------------------- #
# 'live' = SMS-uri REALE (costă bani per mesaj). Guardul cere toate cele 3 chei.
# De unde:
#   Account SID + Auth Token:  https://console.twilio.com/  (pe dashboard)
#   Numărul expeditor:         https://console.twilio.com/us1/develop/phone-numbers/manage/incoming
#     (pentru Moldova/Europa poate fi nevoie de Alphanumeric Sender ID sau de un
#      număr local — verifică regulile țării înainte să cumperi numărul)
OTP_MODE=live
TWILIO_ACCOUNT_SID=<<< COMPLETEAZĂ >>>     # AC...
TWILIO_AUTH_TOKEN=<<< COMPLETEAZĂ >>>
TWILIO_FROM=<<< COMPLETEAZĂ >>>            # ex. +373XXXXXXXX sau FLIRT
OTP_TTL_SECONDS=300
# Folosit DOAR în modul stub. În 'live' e ignorat complet.
OTP_TEST_CODE=000000
SMS_API_KEY=


# --- 7.5 PLĂȚI (OBLIGATORIU) -------------------------------------------------- #
# Decizia de produs: abonamente prin IAP NATIV (App Store / Google Play) — Apple
# obligă la asta pentru conținut digital (Guideline 3.1.1); plata cu cardul prin
# Stripe într-o aplicație de dating din App Store = respingere.
#
# VERIFICARE MODERNĂ (StoreKit 2): clientul mobil (`expo-iap`) trimite un JWS SEMNAT
# de Apple, nu un receipt base64. Serverul îl verifică LOCAL — decodează lanțul de
# certificate din header și îl validează până la Apple Root CA G3. Fără apel de rețea
# în calea achiziției, fără secret partajat. Vechiul `verifyReceipt` + APP_STORE_
# SHARED_SECRET a fost ELIMINAT (accepta orice receipt cu status 0, fără să verifice
# bundle-ul, produsul sau dacă receipt-ul a mai fost folosit).
BILLING_PROVIDER=app_store

# --- App Store (StoreKit 2) --------------------------------------------------- #
# Bundle-ul aplicației. TREBUIE să fie identic cu cel din App Store Connect și din
# `mobile/app.json` (`ios.bundleIdentifier`). O tranzacție semnată pentru alt bundle
# e a altei aplicații și e refuzată.
APP_STORE_BUNDLE_ID=eu.flirt.app
# „Apple ID"-ul NUMERIC al aplicației (NU string): App Store Connect → Apps →
# (aplicația) → App Information → General Information → Apple ID. Obligatoriu pentru
# verificarea în mediul Production.
APP_STORE_APP_APPLE_ID=<<< COMPLETEAZĂ >>>
# Directorul cu certificatele ROOT Apple în format DER (.cer). Descarcă cel puțin
# `AppleRootCA-G3.cer` de la https://www.apple.com/certificateauthority/ și pune-l
# aici. Fără el, lanțul de semnare NU poate fi verificat ⇒ providerul refuză tot.
APP_STORE_ROOT_CERTS_DIR=/etc/flirt/apple-roots
# Verificări OCSP online (revocarea certificatelor de semnare). Implicit oprit: ar
# adăuga un apel de rețea către Apple la fiecare achiziție. Lasă `false` dacă nu ai
# un motiv anume.
APP_STORE_ENABLE_ONLINE_CHECKS=false

# --- Id-urile produselor IAP (App Store Connect / Play Console) --------------- #
# TREBUIE să corespundă EXACT cu produsele configurate în magazine ȘI cu
# `mobile/app.json` (`extra.iapProductIds`). Maparea produs → plan e sursa de adevăr:
# planul acordat se derivă din produsul SEMNAT de magazin, nu din ce cere clientul.
IAP_PRODUCT_PREMIUM=eu.flirt.app.premium.monthly
IAP_PRODUCT_NO_ADS=eu.flirt.app.noads.monthly
IAP_PRODUCT_AI_BOT=eu.flirt.app.aibot.monthly
IAP_PRODUCT_ALL_INCLUSIVE=eu.flirt.app.allinclusive.monthly

# --- Google Play (secundar; setează BILLING_PROVIDER=play ca să-l activezi) ---- #
# Numele pachetului Android (din `mobile/app.json` → `android.package`).
GOOGLE_PLAY_PACKAGE=                       # ex. eu.flirt.app
# Calea către fișierul JSON al SERVICE ACCOUNT-ului cu acces la Play Developer API:
#   Google Play Console → Setup → API access → creează/leagă un service account,
#   apoi Google Cloud → IAM → Service Accounts → Keys → Add key (JSON).
#   Rol necesar: „View financial data / Manage orders and subscriptions".
GOOGLE_PLAY_SERVICE_ACCOUNT_FILE=          # ex. /etc/flirt/play-service-account.json

# Stripe — DOAR dacă treci pe BILLING_PROVIDER=stripe (web/abonamente în afara app-ului):
#   Cheie secretă:   https://dashboard.stripe.com/apikeys
#   Webhook secret:  https://dashboard.stripe.com/webhooks
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
BILLING_API_KEY=
# Prețurile planurilor (EUR) — catalogul din API le citește de aici. Trebuie să
# corespundă EXACT cu prețurile produselor din App Store Connect / Play Console.
PRICE_PREMIUM=9.99
PRICE_NO_ADS=3.99
PRICE_AI_BOT=4.99
PRICE_ALL_INCLUSIVE=14.99


# --- 7.6 VERIFICARE FACIALĂ — AWS Rekognition (OBLIGATORIU) ------------------- #
# Singurul provider implementat în afară de stub. Compară selfie-ul cu fotografiile
# din profil (anti-catfishing). Folosește ACELEAȘI chei AWS de la 7.1 — userul IAM
# are nevoie în plus de permisiunea `rekognition:CompareFaces`.
#   Consolă: https://console.aws.amazon.com/rekognition/
#   (Nu e disponibil în toate regiunile — verifică-ți S3_REGION.)
FACE_VERIFY_PROVIDER=rekognition
FACE_MATCH_THRESHOLD=90.0                  # scor minim de similaritate (0-100)


# --- 7.7 NOTIFICĂRI PUSH — Expo (OBLIGATORIU, dar fără cheie) ----------------- #
# 'expo' folosește serviciul Expo Push (gratuit, fără cheie API) și e alegerea
# firească pentru o aplicație Expo. Guardul nu cere nicio cheie pentru el.
PUSH_PROVIDER=expo
PUSH_API_KEY=
# FCM — doar dacă treci pe PUSH_PROVIDER=fcm (atunci cheia e OBLIGATORIE):
#   https://console.firebase.google.com/ → Project settings → Cloud Messaging
FCM_SERVER_KEY=


# ============================================================================ #
#  8. REGULI DE PRODUS  (valori bune implicit — schimbă doar dacă știi de ce)
# ============================================================================ #
# APLICAȚIA E 18+ ONLY (cerință App Store / Google Play pentru dating).
# Config-ul REFUZĂ să pornească dacă MIN_REGISTRATION_AGE < ADULT_AGE.
MIN_REGISTRATION_AGE=18
ADULT_AGE=18
MIN_PHOTOS=3
MAX_PHOTOS=9
ABOUT_MAX_LENGTH=500
ACCOUNT_DELETION_GRACE_DAYS=30
STORY_TTL_HOURS=24
REPORT_AUTOBAN_THRESHOLD=3

# Feed / căutare
FEED_LIMIT=10
FEED_MAX_LIMIT=50
FEED_SCAN_LIMIT=500
SEARCH_RADIUS_DEFAULT_KM=50
SEARCH_AGE_MIN_DEFAULT=18
SEARCH_AGE_MAX_DEFAULT=99
SEARCH_AGE_MAX_LIMIT=120
SEARCH_RADIUS_MAX_KM=1000
FEED_RADIUS_FILTER_ENABLED=true
FEED_MAX_INACTIVE_DAYS=30
LAST_ACTIVE_TOUCH_MINUTES=15

# Ponderi Compatibility Score (suma = 1.0)
COMPAT_W_INTERESTS=0.30
COMPAT_W_STATUS=0.15
COMPAT_W_HUMOR=0.20
COMPAT_W_DISTANCE=0.15
COMPAT_W_LANGUAGES=0.10
COMPAT_W_BEHAVIOR=0.10


# ============================================================================ #
#  9. SECURITATE / LIMITE  (valori bune implicit)
# ============================================================================ #
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_PER_MIN=5
RATE_LIMIT_REGISTER_PER_HOUR=10
OTP_REQUEST_PER_HOUR=5
OTP_MAX_ATTEMPTS=5
MAX_UPLOAD_BYTES=8388608                   # 8 MB (nginx acceptă 12m — vezi nginx.conf)
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
FREE_DAILY_SWIPE_LIMIT=50


# ============================================================================ #
#  10. OPERAȚIONAL
# ============================================================================ #
# Log-uri: JSON pe stdout, colectate de Docker (rotate la 10 MB × 5 fișiere).
LOG_LEVEL=INFO
LOG_FORMAT=json

# Gunicorn. Regulă de start: 2 × nr. vCPU + 1. Pe un server cu 2 vCPU → 4-5.
# Fiecare worker ține propriul pool de conexiuni la Postgres — nu-l crește orbește.
WEB_CONCURRENCY=4
FORWARDED_ALLOW_IPS=*                      # avem încredere în X-Forwarded-* doar de la nginx
GUNICORN_TIMEOUT=60
GUNICORN_GRACEFUL_TIMEOUT=30

# Purjare GDPR (serviciul `purge`): șterge definitiv conturile cu grația expirată.
GDPR_PURGE_INTERVAL_SECONDS=3600

# Backup (serviciul `backup`): pg_dump comprimat + retenție.
# ⚠️  BACKUP_HOST_DIR ar trebui să fie pe un DISC SEPARAT (sau sincronizat off-site).
#     Un backup pe același disc cu baza de date dispare odată cu discul.
BACKUP_INTERVAL_SECONDS=86400              # zilnic
BACKUP_RETENTION_DAYS=14
BACKUP_HOST_DIR=./backups

# Panoul de admin (folderul `admin/`, build Vite servit de nginx pe ADMIN_DOMAIN).
# VITE_API_URL se compune automat din DOMAIN dacă îl lași gol.
VITE_API_URL=
ADMIN_BUILD_DIR=dist
