# === FLIRT backend — variabile de mediu (NIMIC hardcodat în cod) ===
# Copiază în `.env` și completează. NU comita `.env`.
#
# ⚠️  ACEST FIȘIER E PENTRU DEZVOLTARE LOCALĂ (integrări în modul `stub`).
#     Pentru PRODUCȚIE folosește `.env.production.example` — acolo sunt TOATE
#     variabilele pe care guardul din `app/core/config.py` le cere ca să pornească,
#     fiecare cu explicație și cu URL-ul de unde se ia cheia.

# App
APP_NAME=FLIRT
ENVIRONMENT=development            # development | staging | production
API_V1_PREFIX=/api/v1
DEBUG=true

# Database (Postgres în docker-compose; SQLite doar în teste)
POSTGRES_USER=flirt
POSTGRES_PASSWORD=change_me
POSTGRES_DB=flirt
POSTGRES_HOST=db
POSTGRES_PORT=5432
# DATABASE_URL se compune automat din variabilele de mai sus dacă e gol.
DATABASE_URL=

# JWT (RS256). Generează chei:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# și pune conținutul PEM (multiline) aici, sau montează fișierele.
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS — cine poate chema API-ul din BROWSER.
# Aplicația mobilă (React Native) NU trimite `Origin`: CORS nu o afectează. Singura
# suprafață web e panoul de admin. În dev: serverul de dezvoltare Vite/Expo.
# În producție: https://admin.flirt.md (vezi .env.production.example).
# 5173/5174 = serverul de dezvoltare Vite al panoului de admin (`admin/`). Vite
# trece automat pe 5174 când 5173 e ocupat, deci ambele porturi trebuie permise —
# altfel panoul pornit „pe portul următor" primește erori CORS opace în browser.
CORS_ORIGINS=http://localhost:19006,http://localhost:8081,http://localhost:5173,http://localhost:5174

# Anketă / reguli produs
# APLICAȚIA E 18+ ONLY (cerință App Store / Google Play pentru dating).
# MIN_REGISTRATION_AGE nu poate fi sub ADULT_AGE — config-ul refuză să pornească.
MIN_REGISTRATION_AGE=18
MIN_PHOTOS=3
MAX_PHOTOS=9
SEARCH_RADIUS_DEFAULT_KM=50      # raza implicită; SE APLICĂ efectiv în feed
ACCOUNT_DELETION_GRACE_DAYS=30
ABOUT_MAX_LENGTH=500             # lungimea maximă a câmpului „despre" (TZ 2.4)

# Feed / vârstă
ADULT_AGE=18                      # pragul legal de adult (18+ only)
FEED_LIMIT=10                     # câte cartele întoarce feed-ul implicit
FEED_MAX_LIMIT=50                 # plafon pentru ?limit= pe GET /feed (anti-DoS)
FEED_SCAN_LIMIT=500               # câți candidați intră în fereastra de ranking

# Preferințe de căutare (valorile implicite când userul nu a setat nimic)
SEARCH_AGE_MIN_DEFAULT=18         # ridicat automat la ADULT_AGE dacă e mai mic
SEARCH_AGE_MAX_DEFAULT=99
SEARCH_AGE_MAX_LIMIT=120          # plafon absolut acceptat de la client
SEARCH_RADIUS_MAX_KM=1000         # plafon absolut pentru raza de căutare
FEED_RADIUS_FILTER_ENABLED=true   # false = ignoră raza (piețe cu densitate mică)

# Activitate (users.last_active_at)
FEED_MAX_INACTIVE_DAYS=30         # candidații inactivi de peste N zile ies din feed (0 = oprit)
LAST_ACTIVE_TOUCH_MINUTES=15      # prag de scriere (evită un UPDATE la fiecare request)

# Stories
STORY_TTL_HOURS=24               # durata de viață a unei povești (TZ 11)

# Moderare
REPORT_AUTOBAN_THRESHOLD=3       # câte rapoarte distincte → auto-ascundere cont

# === Integrări externe (stub implicit; setează provider + chei la deploy) ===
# Storage foto
STORAGE_PROVIDER=stub            # stub | s3
STORAGE_BASE_URL=https://cdn.flirt.local
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Geolocație
# Geocodarea se face O SINGURĂ DATĂ, la salvarea anketei (lat/lng se persistă pe
# profil) — feed-ul NU mai face niciun apel de rețea per candidat.
GEO_PROVIDER=stub                # stub | nominatim | google | mapbox
GEO_BASE_URL=https://nominatim.openstreetmap.org
GEO_USER_AGENT=FLIRT/0.1 (contact@example.com)   # obligatoriu pentru Nominatim
GEO_MAX_LOOKUPS_PER_REQUEST=25   # plafon de geocodări noi per cerere (anti-cost)
GEO_API_KEY=
# Auth providers + OTP
SOCIAL_AUTH_MODE=stub            # stub | live
APPLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
OTP_MODE=stub                    # stub | live
OTP_TEST_CODE=000000
OTP_TTL_SECONDS=300
SMS_API_KEY=
# Push
PUSH_PROVIDER=stub               # stub | expo | fcm
PUSH_API_KEY=
# Billing
BILLING_PROVIDER=stub            # stub | stripe | app_store | play
BILLING_API_KEY=
# Prețuri planuri abonament (EUR) — catalogul billing citește de aici (TZ 9)
PRICE_PREMIUM=9.99
PRICE_NO_ADS=3.99
PRICE_AI_BOT=4.99
PRICE_ALL_INCLUSIVE=14.99
# Verificare facială
FACE_VERIFY_PROVIDER=stub        # stub | rekognition
FACE_MATCH_THRESHOLD=90.0        # scor minim similaritate (0-100)
# Redis (OTP live / cache / RATE LIMITING partajat între workeri)
# OBLIGATORIU în producție: fără el, rate limiting-ul e per proces — cu 4 workeri
# gunicorn limita reală devine 4× cea configurată (și 0 la scale-out orizontal).
# În docker-compose e setat automat la redis://redis:6379/0.
REDIS_URL=                       # ex. redis://localhost:6379/0
# SMS Twilio (OTP live)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
# Stripe (billing live)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# App Store / Google Play (verificare receipt)
APP_STORE_SHARED_SECRET=
GOOGLE_PLAY_PACKAGE=
# FCM (push live)
FCM_SERVER_KEY=

# Ponderi Compatibility Score (sumă = 1.0, TZ 4.6)
COMPAT_W_INTERESTS=0.30
COMPAT_W_STATUS=0.15
COMPAT_W_HUMOR=0.20
COMPAT_W_DISTANCE=0.15
COMPAT_W_LANGUAGES=0.10
COMPAT_W_BEHAVIOR=0.10

# === Operațional / deployment (vezi docs/DEPLOYMENT.md) ======================
# TLS — nginx randează `server_name` din ACESTE variabile și caută certificatul
# Let's Encrypt pentru ele. Local, lasă `localhost`: se generează automat un
# certificat self-signed, iar certbot nu încearcă nimic (nu poate valida localhost).
# În producție: DOMAIN=api.flirt.md, ADMIN_DOMAIN=admin.flirt.md
DOMAIN=localhost
ADMIN_DOMAIN=admin.localhost     # panoul de admin (SPA static din `admin/`)
CERTBOT_EMAIL=                   # email pentru avertizări de expirare (Let's Encrypt)
CERTBOT_STAGING=false            # true = mediul de test LE (fără limite de rată)

# Panoul de admin — build Vite (serviciul `admin-build` din compose).
# Gol → se compune din DOMAIN. Build-ul e tolerant: dacă `admin/` nu există, nu
# blochează pornirea backend-ului.
VITE_API_URL=
ADMIN_BUILD_DIR=dist

# Logging structurat (JSON pe stdout — colectat de Docker/systemd/Loki)
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                  # json (producție) | text (dev, mai lizibil)

# Gunicorn
WEB_CONCURRENCY=4                # workeri (regulă de start: 2 × nr. vCPU + 1)
FORWARDED_ALLOW_IPS=*            # avem încredere în X-Forwarded-* DOAR de la nginx
GUNICORN_TIMEOUT=60
GUNICORN_GRACEFUL_TIMEOUT=30

# Purjare GDPR (serviciul `purge` din compose — șterge definitiv conturile
# a căror perioadă de grație a expirat). Minim acceptat: 60s.
GDPR_PURGE_INTERVAL_SECONDS=3600

# Backup DB (serviciul `backup` din compose: pg_dump comprimat + retenție)
BACKUP_INTERVAL_SECONDS=86400    # zilnic
BACKUP_RETENTION_DAYS=14
BACKUP_HOST_DIR=./backups        # ideal: un disc/volum SEPARAT de cel al DB-ului
