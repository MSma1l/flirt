# === FLIRT backend — variabile de mediu (NIMIC hardcodat în cod) ===
# Copiază în `.env` și completează. NU comita `.env`.

# App
APP_NAME=FLIRT
ENVIRONMENT=development            # development | staging | production
API_V1_PREFIX=/api/v1
DEBUG=true

# Database (Postgres în docker-compose; SQLite doar în teste)
POSTGRES_USER=flirt
POSTGRES_PASSWORD=change_me
POSTGRES_DB=flirt
POSTGRES_HOST=db
POSTGRES_PORT=5432
# DATABASE_URL se compune automat din variabilele de mai sus dacă e gol.
DATABASE_URL=

# JWT (RS256). Generează chei:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# și pune conținutul PEM (multiline) aici, sau montează fișierele.
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS (listă separată prin virgulă a originilor mobile/dev)
CORS_ORIGINS=http://localhost:19006,http://localhost:8081

# Anketă / reguli produs
MIN_REGISTRATION_AGE=16
MIN_PHOTOS=3
MAX_PHOTOS=9
